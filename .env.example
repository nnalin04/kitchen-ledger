# ============================================================
# KitchenLedger — Environment Variables
# Copy this file to .env and fill in all values before running
# docker-compose up. Never commit .env to source control.
# ============================================================

# ────────────────────────────────────────────────────────────
# INFRASTRUCTURE
# ────────────────────────────────────────────────────────────

# PostgreSQL (used by Java + Python services)
POSTGRES_DB=kitchenledger
POSTGRES_USER=kl_user
POSTGRES_PASSWORD=kl_password

# Redis
REDIS_URL=redis://redis:6379

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_USERNAME=kl_rabbit
RABBITMQ_PASSWORD=kl_rabbit_pass
RABBITMQ_URL=amqp://kl_rabbit:kl_rabbit_pass@rabbitmq:5672

# Internal service-to-service secret (for /internal/* routes)
INTERNAL_SERVICE_SECRET=change-me-in-production-use-a-long-random-string

# ────────────────────────────────────────────────────────────
# API GATEWAY (port 8080)
# ────────────────────────────────────────────────────────────
# RSA public key for JWT verification (PEM, single line with \n)
JWT_PUBLIC_KEY=

# Service URLs (internal Docker network)
AUTH_SERVICE_URL=http://auth-service:8081
INVENTORY_SERVICE_URL=http://inventory-service:8082
FINANCE_SERVICE_URL=http://finance-service:8083
STAFF_SERVICE_URL=http://staff-service:8088
AI_SERVICE_URL=http://ai-service:8084
FILE_SERVICE_URL=http://file-service:8085
NOTIFICATION_SERVICE_URL=http://notification-service:8086
REPORT_SERVICE_URL=http://report-service:8087

# ────────────────────────────────────────────────────────────
# AUTH SERVICE (port 8081)
# ────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/kitchenledger
SPRING_DATASOURCE_USERNAME=kl_user
SPRING_DATASOURCE_PASSWORD=kl_password

# RSA key pair for JWT signing (RS256)
# Generate with: openssl genrsa -out private.pem 2048
#                openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key

# For dev: base64-encoded PEM strings (alternative to file paths)
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=

# Access token expiry (minutes)
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
# Refresh token expiry (days)
JWT_REFRESH_TOKEN_EXPIRY_DAYS=30

# Resend (email sending)
RESEND_API_KEY=re_xxxx

# ────────────────────────────────────────────────────────────
# INVENTORY SERVICE (port 8082)
# ────────────────────────────────────────────────────────────
# (uses shared SPRING_DATASOURCE_* vars above)

# ────────────────────────────────────────────────────────────
# FINANCE SERVICE (port 8083)
# ────────────────────────────────────────────────────────────
# (uses shared SPRING_DATASOURCE_* vars above)

# ────────────────────────────────────────────────────────────
# STAFF SERVICE (port 8088)
# ────────────────────────────────────────────────────────────
# (uses shared SPRING_DATASOURCE_* vars above)

# ────────────────────────────────────────────────────────────
# AI SERVICE (port 8084)
# ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kl_user:kl_password@postgres:5432/kitchenledger

# OpenAI
OPENAI_API_KEY=sk-xxxx

# Google Cloud Vision (service account JSON, base64-encoded)
GOOGLE_CLOUD_CREDENTIALS=

# Mindee (receipt/invoice OCR)
MINDEE_API_KEY=

# ────────────────────────────────────────────────────────────
# FILE SERVICE (port 8085)
# ────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJxxx
SUPABASE_STORAGE_BUCKET=kitchenledger-files
MAX_FILE_SIZE_MB=10

# ────────────────────────────────────────────────────────────
# NOTIFICATION SERVICE (port 8086)
# ────────────────────────────────────────────────────────────
# (uses DATABASE_URL above)

# Expo push notifications
EXPO_ACCESS_TOKEN=

# Resend (shared with Auth)
# RESEND_API_KEY already defined above

# ────────────────────────────────────────────────────────────
# REPORT SERVICE (port 8087)
# ────────────────────────────────────────────────────────────
# (uses DATABASE_URL, REDIS_URL, RABBITMQ_URL above)
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1

# ────────────────────────────────────────────────────────────
# FRONTEND
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
